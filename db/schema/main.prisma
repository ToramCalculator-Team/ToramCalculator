/**
 * @file main.prisma
 * @description 数据库架构文件
 * 表命名规范：
 * 1.小写字母 + 下划线
 * 关系字段外键前缀规则：
 * 1.OneToOne: XXX（子关系直接使用子表名）/belongToXXX（父关系使用belongTo前缀+父表名）
 * 2.OneToMany: XXX（子关系直接使用子表名）/usedByXXX（父关系使用usedBy前缀+父表名）
 * 3.ManyToOne: XXX（子关系直接使用子表名）/belongToXXX（父关系使用belongTo前缀+父表名）
 * 4.ManyToMany: XXX（子关系直接使用子表名）/usedByXXX（父关系使用usedBy前缀+父表名）
 */

generator custom {
    provider = "tsx ./db/generator/generator.ts"
    output   = "../generated/"
}

datasource db {
    provider = "postgresql"
}

// 同步延迟探针表
// 设计目的：服务端定时写入 emitted_at（PG 时钟），客户端经 Electric 同步后用本地时钟对比，估算读路径端到端延迟。
// 固定单行（id 常量），服务端用 upsert 不断刷新 emitted_at。
model sync_heartbeat {
    id         String   @id
    seq        BigInt
    emitted_at DateTime
}
